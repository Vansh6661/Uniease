import { useState, useRef } from "react";

const BG = "";

const CLOTH_OPTIONS = [
  { value: "shirt",    label: "Shirt",    emoji: "👔" },
  { value: "pant",     label: "Pant",     emoji: "👖" },
  { value: "t-shirt",  label: "T-Shirt",  emoji: "👕" },
  { value: "bedsheet", label: "Bedsheet", emoji: "🛏️" },
  { value: "towel",    label: "Towel",    emoji: "🧺" },
];

const SEED_ORDERS = [
  { id: 1001, clothType: "shirt",   quantity: 3, status: "Ready",      date: "Mar 18" },
  { id: 1002, clothType: "pant",    quantity: 2, status: "Processing", date: "Mar 15" },
  { id: 1003, clothType: "t-shirt", quantity: 5, status: "Delivered",  date: "Mar 10" },
];

const MENU = {
  Breakfast: [
    { id: 1, name: "Aloo Paratha",   price: 40, emoji: "🫓" },
    { id: 2, name: "Poha",           price: 30, emoji: "🍚" },
    { id: 3, name: "Masala Dosa",    price: 50, emoji: "🥞" },
    { id: 4, name: "Bread Omelette", price: 35, emoji: "🍳" },
  ],
  Lunch: [
    { id: 5, name: "Rajma Rice",           price: 70,  emoji: "🍛" },
    { id: 6, name: "Paneer Butter Masala", price: 90,  emoji: "🍲" },
    { id: 7, name: "Dal Tadka",            price: 60,  emoji: "🥣" },
    { id: 8, name: "Veg Thali",            price: 100, emoji: "🍱" },
  ],
  Snacks: [
    { id: 9,  name: "Samosa (2pc)", price: 20, emoji: "🥟" },
    { id: 10, name: "Maggi",        price: 30, emoji: "🍜" },
    { id: 11, name: "Cold Coffee",  price: 40, emoji: "☕" },
    { id: 12, name: "Veg Sandwich", price: 45, emoji: "🥪" },
  ],
};

const COMPLAINT_CATS = [
  "Hostel & Accommodation","Academic","Canteen / Food",
  "Transport","Infrastructure","IT / Wi-Fi","Other"
];

const SUBJECTS = [
  { code:"CS301", name:"Data Structures",     credits:4, grade:"A",  marks:91, att:88 },
  { code:"CS302", name:"Operating Systems",   credits:4, grade:"A-", marks:84, att:76 },
  { code:"CS303", name:"Computer Networks",   credits:3, grade:"B+", marks:78, att:92 },
  { code:"CS304", name:"DBMS",                credits:4, grade:"A+", marks:95, att:96 },
  { code:"MA301", name:"Probability & Stats", credits:3, grade:"B",  marks:72, att:70 },
];

const TIMETABLE = [
  { day:"Mon", slots:["DS 9AM","OS 11AM","DBMS 2PM"] },
  { day:"Tue", slots:["CN 9AM","Stats 11AM","Lab 2PM"] },
  { day:"Wed", slots:["DS 9AM","DBMS 11AM","OS 2PM"] },
  { day:"Thu", slots:["CN 9AM","Stats 11AM","DS Lab 2PM"] },
  { day:"Fri", slots:["OS 9AM","DBMS 11AM"] },
];

const STATUS_STYLE = {
  Processing: { bg:"#fff7ed", color:"#9a3412", dot:"#f97316" },
  Ready:      { bg:"#f0fdf4", color:"#14532d", dot:"#22c55e" },
  Delivered:  { bg:"#eff6ff", color:"#1e3a8a", dot:"#3b82f6" },
  Open:       { bg:"#eff6ff", color:"#1e3a8a", dot:"#3b82f6" },
  Resolved:   { bg:"#f0fdf4", color:"#14532d", dot:"#22c55e" },
  "In Progress": { bg:"#fff7ed", color:"#9a3412", dot:"#f97316" },
};

const GRADE_COLOR = { "A+":"#166534",A:"#166534","A-":"#166534","B+":"#1d4ed8",B:"#1d4ed8" };
const GRADE_BG    = { "A+":"#dcfce7",A:"#dcfce7","A-":"#f0fdf4","B+":"#eff6ff",B:"#dbeafe" };
const EMOJI_MAP   = { shirt:"👔", pant:"👖", "t-shirt":"👕", bedsheet:"🛏️", towel:"🧺" };
const PAGES = { login:true, services:true, academic:true, complaint:true, food:true, laundry:true };

export default function App() {
  const [page, setPage]       = useState("login");
  const [user, setUser]       = useState(null);
  const [toast, setToast]     = useState(null);
  const [mobNav, setMobNav]   = useState(false);
  const tRef = useRef(null);

  const go = (p) => { if (PAGES[p]) { setPage(p); setMobNav(false); } };

  const showToast = (msg, type = "success") => {
    setToast({ msg, type });
    clearTimeout(tRef.current);
    tRef.current = setTimeout(() => setToast(null), 3200);
  };

  const NAV = [
    { id:"services",  label:"Home" },
    { id:"academic",  label:"Academic" },
    { id:"food",      label:"Food" },
    { id:"laundry",   label:"Laundry" },
    { id:"complaint", label:"Complaint" },
  ];

  return (
    <>
      <style>{CSS}</style>

      {/* BG */}
      <div className="bg-wrap">
        <img src={`data:image/jpeg;base64,${BG}`} className="bg-img" alt="" />
        <div className="bg-ov" />
      </div>

      {/* NAV */}
      {user && page !== "login" && (
        <>
          <nav className="nav">
            <button className="logo" onClick={() => go("services")}>
              <span className="logo-box">U</span>UniEase
            </button>
            <div className="nav-links">
              {NAV.map(n => (
                <button key={n.id}
                  className={"nb" + (page === n.id ? " nb-a" : "")}
                  onClick={() => go(n.id)}>{n.label}
                </button>
              ))}
            </div>
            <div className="nav-r">
              <div className="av-sm">{user.name?.[0] ?? "S"}</div>
              <button className="ham" onClick={() => setMobNav(v => !v)}>
                <span /><span /><span />
              </button>
            </div>
          </nav>
          {mobNav && (
            <div className="mob-menu">
              {NAV.map(n => (
                <button key={n.id}
                  className={"mb" + (page === n.id ? " mb-a" : "")}
                  onClick={() => go(n.id)}>{n.label}
                </button>
              ))}
            </div>
          )}
        </>
      )}

      {/* PAGES */}
      <main className={page === "services" ? "main-svc" : "main"}>
        {page === "login"     && <LoginPage     go={go} setUser={setUser} />}
        {page === "services"  && <ServicesPage  go={go} user={user} />}
        {page === "academic"  && <AcademicPage  go={go} />}
        {page === "complaint" && <ComplaintPage go={go} showToast={showToast} />}
        {page === "food"      && <FoodPage      go={go} showToast={showToast} />}
        {page === "laundry"   && <LaundryPage   go={go} showToast={showToast} />}
      </main>

      {/* TOAST */}
      {toast && (
        <div className={"toast toast-" + toast.type}>
          <span className="toast-ic">{toast.type === "success" ? "✓" : "!"}</span>
          {toast.msg}
        </div>
      )}
    </>
  );
}

/* ══════════════════ LOGIN ══════════════════ */
function LoginPage({ go, setUser }) {
  const [email, setEmail]   = useState("");
  const [pass, setPass]     = useState("");
  const [err, setErr]       = useState("");
  const [loading, setLoading] = useState(false);

  const submit = () => {
    setErr("");
    if (!email.includes("@")) { setErr("Enter a valid email address"); return; }
    if (pass.length < 4)      { setErr("Password must be at least 4 characters"); return; }
    setLoading(true);
    setTimeout(() => {
      const name = email.split("@")[0];
      setUser({ email, name: name.charAt(0).toUpperCase() + name.slice(1) });
      setLoading(false);
      go("services");
    }, 900);
  };

  return (
    <div className="login-wrap">
      <div className="login-card">
        <div className="login-top">
          <div className="login-icon-box">U</div>
          <div>
            <div className="login-brand">UniEase</div>
            <div className="login-sub">Bennett University Student Portal</div>
          </div>
        </div>
        <div className="login-div" />
        <div className="field">
          <label className="lbl">University Email</label>
          <input className={"ctrl" + (err ? " err" : "")} type="email"
            placeholder="s24cseu2266@bennett.edu.in"
            value={email} onChange={e => setEmail(e.target.value)}
            onKeyDown={e => e.key === "Enter" && submit()} />
        </div>
        <div className="field">
          <label className="lbl">Password</label>
          <input className={"ctrl" + (err ? " err" : "")} type="password"
            placeholder="Enter your password"
            value={pass} onChange={e => setPass(e.target.value)}
            onKeyDown={e => e.key === "Enter" && submit()} />
        </div>
        {err && <div className="err-msg">{err}</div>}
        <button className="btn btn-p full mt8" onClick={submit} disabled={loading}>
          {loading ? <><span className="spin" /> Signing in…</> : "Sign In →"}
        </button>
        <div className="login-hint">Use any email + any 4-char password to demo</div>
      </div>
    </div>
  );
}

/* ══════════════════ SERVICES ══════════════════ */
const SVCS = [
  { id:"academic",  icon:"🎓", title:"Academic Portal",  desc:"Grades, attendance & timetable", active:true },
  { id:"food",      icon:"🍽️", title:"Food Order",       desc:"Canteen & mess ordering",        active:true },
  { id:"laundry",   icon:"👕", title:"Laundry",          desc:"Submit & track laundry orders",  active:true },
  { id:"complaint", icon:"📢", title:"Raise Complaint",  desc:"Hostel, academic & other issues",active:true },
  { id:"library",   icon:"📚", title:"Library",          desc:"Book search & reservations",     active:false },
  { id:"transport", icon:"🚌", title:"Transport",        desc:"Bus routes & schedules",         active:false },
  { id:"sports",    icon:"⚽", title:"Sports Facility",  desc:"Book courts & equipment",        active:false },
  { id:"health",    icon:"🏥", title:"Health Centre",    desc:"Appointments & records",         active:false },
];

function ServicesPage({ go, user }) {
  return (
    <div className="svc-wrap">
      <div className="svc-hero">
        <div className="svc-greet">Welcome back, {user?.name?.split(" ")[0] ?? "Student"} 👋</div>
        <h1 className="svc-h1">What can we help<br />you with today?</h1>
        <p className="svc-sub">All your campus services in one place</p>
      </div>
      <div className="svc-grid">
        {SVCS.map(s => (
          <button key={s.id} className={"svc-card" + (!s.active ? " svc-dim" : "")}
            onClick={() => s.active && go(s.id)}>
            <div className="svc-emoji">{s.icon}</div>
            <div className="svc-title">{s.title}</div>
            <div className="svc-desc">{s.desc}</div>
            {!s.active && <span className="svc-pill">Coming soon</span>}
          </button>
        ))}
      </div>
    </div>
