}

/* ══════════════════ ACADEMIC ══════════════════ */
function AcademicPage({ go }) {
  const [tab, setTab] = useState("grades");
  const avgAtt = Math.round(SUBJECTS.reduce((s, x) => s + x.att, 0) / SUBJECTS.length);

  return (
    <div className="pg-wrap">
      <PageHeader title="Academic Portal" icon="🎓" back={() => go("services")} />
      <div className="stat-row">
        {[["CGPA","8.76","#1d4ed8"],["Attendance",avgAtt+"%",avgAtt<75?"#dc2626":"#166534"],["Semester","6th","#7c3aed"],["Credits","82","#0369a1"]].map(([l,v,c]) => (
          <div className="stat-card" key={l}>
            <div className="stat-val" style={{color:c}}>{v}</div>
            <div className="stat-lbl">{l}</div>
          </div>
        ))}
      </div>
      <div className="tabs">
        {["grades","attendance","timetable"].map(t => (
          <button key={t} className={"tab"+(tab===t?" tab-a":"")} onClick={() => setTab(t)}>
            {t.charAt(0).toUpperCase()+t.slice(1)}
          </button>
        ))}
      </div>

      {tab === "grades" && (
        <div className="card">
          <table className="tbl">
            <thead><tr><th>Code</th><th>Subject</th><th>Credits</th><th>Marks</th><th>Grade</th></tr></thead>
            <tbody>
              {SUBJECTS.map(s => (
                <tr key={s.code}>
                  <td className="mono">{s.code}</td><td>{s.name}</td>
                  <td className="tc">{s.credits}</td><td className="tc">{s.marks}</td>
                  <td className="tc">
                    <span className="badge" style={{background:GRADE_BG[s.grade]||"#f1f5f9",color:GRADE_COLOR[s.grade]||"#334155"}}>{s.grade}</span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      {tab === "attendance" && (
        <div className="card">
          <div className="att-list">
            {SUBJECTS.map(s => (
              <div className="att-row" key={s.code}>
                <div><div className="att-name">{s.name}</div><div className="att-code">{s.code}</div></div>
                <div className="att-bar-wrap">
                  <div className="att-bar">
                    <div className="att-fill" style={{width:s.att+"%",background:s.att<75?"#ef4444":"#22c55e"}} />
                  </div>
                  <span className="att-pct" style={{color:s.att<75?"#dc2626":"#166534"}}>{s.att}%</span>
                </div>
              </div>
            ))}
          </div>
          <div className="att-note">⚠️ Minimum 75% attendance required per subject.</div>
        </div>
      )}

      {tab === "timetable" && (
        <div className="card">
          <div className="tt-grid">
            {TIMETABLE.map(d => (
              <div className="tt-col" key={d.day}>
                <div className="tt-day">{d.day}</div>
                {d.slots.map((sl,i) => <div className="tt-slot" key={i}>{sl}</div>)}
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  );
}

/* ══════════════════ COMPLAINT ══════════════════ */
const SEED_COMPLAINTS = [
  { id:"CMP-204", cat:"IT / Wi-Fi",            title:"Wi-Fi down in Block B",    status:"In Progress", date:"Mar 19" },
  { id:"CMP-198", cat:"Hostel & Accommodation", title:"Water leakage in room 312",status:"Resolved",    date:"Mar 12" },
];

function ComplaintPage({ go, showToast }) {
  const [tab, setTab]       = useState("new");
  const [cat, setCat]       = useState("");
  const [title, setTitle]   = useState("");
  const [desc, setDesc]     = useState("");
  const [errors, setErrors] = useState({});
  const [loading, setLoading] = useState(false);
  const [list, setList]     = useState(SEED_COMPLAINTS);

  const submit = () => {
    const e = {};
    if (!cat)   e.cat   = "Select a category";
    if (!title) e.title = "Enter a title";
    if (!desc)  e.desc  = "Describe the issue";
    setErrors(e);
    if (Object.keys(e).length) return;
    setLoading(true);
    setTimeout(() => {
      const newId = "CMP-" + (205 + list.length);
      setList(prev => [{ id:newId, cat, title, status:"Open",
        date: new Date().toLocaleDateString("en-US",{month:"short",day:"numeric"})
      }, ...prev]);
      setCat(""); setTitle(""); setDesc(""); setErrors({});
      setLoading(false); setTab("track");
      showToast("Complaint submitted! ID: " + newId);
    }, 900);
  };

  return (
    <div className="pg-wrap">
      <PageHeader title="Raise a Complaint" icon="📢" back={() => go("services")} />
      <div className="tabs">
        <button className={"tab"+(tab==="new"?" tab-a":"")} onClick={() => setTab("new")}>New Complaint</button>
        <button className={"tab"+(tab==="track"?" tab-a":"")} onClick={() => setTab("track")}>My Complaints ({list.length})</button>
      </div>
      {tab === "new" && (
        <div className="card">
          <div className="field">
            <label className="lbl">Category</label>
            <select className={"ctrl"+(errors.cat?" err":"")} value={cat}
              onChange={e => { setCat(e.target.value); setErrors(v => ({...v,cat:null})); }}>
              <option value="">Select category…</option>
              {COMPLAINT_CATS.map(c => <option key={c} value={c}>{c}</option>)}
            </select>
            {errors.cat && <div className="err-msg">{errors.cat}</div>}
          </div>
          <div className="field">
            <label className="lbl">Title</label>
            <input className={"ctrl"+(errors.title?" err":"")} placeholder="Brief title of the issue"
              value={title} onChange={e => { setTitle(e.target.value); setErrors(v => ({...v,title:null})); }} />
            {errors.title && <div className="err-msg">{errors.title}</div>}
          </div>
          <div className="field">
            <label className="lbl">Description</label>
            <textarea className={"ctrl ta"+(errors.desc?" err":"")} rows={4}
              placeholder="Describe the issue in detail…"
              value={desc} onChange={e => { setDesc(e.target.value); setErrors(v => ({...v,desc:null})); }} />
            {errors.desc && <div className="err-msg">{errors.desc}</div>}
          </div>
          <button className="btn btn-p" onClick={submit} disabled={loading}>
            {loading ? <><span className="spin" /> Submitting…</> : "Submit Complaint"}
          </button>
        </div>
      )}
      {tab === "track" && (
        <div className="card">
          {list.map(c => {
            const s = STATUS_STYLE[c.status] || STATUS_STYLE.Open;
            return (
              <div className="c-row" key={c.id}>
                <div>
                  <div className="c-id">{c.id}</div>
                  <div className="c-title">{c.title}</div>
                  <div className="c-cat">{c.cat} · {c.date}</div>
                </div>
                <span className="badge" style={{background:s.bg,color:s.color}}>
                  <span className="bdot" style={{background:s.dot}} />{c.status}
                </span>
              </div>
            );
          })}
        </div>
      )}
    </div>
  );
}

/* ══════════════════ FOOD ══════════════════ */
function FoodPage({ go, showToast }) {
  const [cat, setCat]   = useState("Breakfast");
  const [cart, setCart] = useState({});
  const [placing, setPlacing] = useState(false);

  const add    = (id) => setCart(c => ({...c,[id]:(c[id]||0)+1}));
  const remove = (id) => setCart(c => { const n={...c}; n[id]>1?n[id]--:delete n[id]; return n; });
  const total  = Object.entries(cart).reduce((s,[id,qty]) => {
    const item = Object.values(MENU).flat().find(x => x.id===+id);
    return s + (item?.price||0)*qty;
  }, 0);
  const count  = Object.values(cart).reduce((s,v) => s+v, 0);

  const placeOrder = async () => {
    setPlacing(true);
    try {
      await fetch("http://localhost:3001/api/food/order", {
        method:"POST", headers:{"Content-Type":"application/json"},
        body: JSON.stringify({ items: cart, total }),
      });
    } catch(_) {}
    showToast("Order placed! Ready in ~20 mins 🍽️");
    setCart({}); setPlacing(false);
  };

  return (
    <div className="pg-wrap">
      <PageHeader title="Food Order" icon="🍽️" back={() => go("services")} />
      <div className="tabs">
        {Object.keys(MENU).map(c => (
          <button key={c} className={"tab"+(cat===c?" tab-a":"")} onClick={() => setCat(c)}>{c}</button>
        ))}
      </div>
      <div className="food-grid">
        {MENU[cat].map(item => {
          const qty = cart[item.id]||0;
          return (
            <div className="food-card" key={item.id}>
              <div className="food-emoji">{item.emoji}</div>
              <div className="food-name">{item.name}</div>
              <div className="food-price">₹{item.price}</div>
              {qty===0
                ? <button className="btn-add" onClick={() => add(item.id)}>Add +</button>
                : <div className="qty-ctrl">
                    <button className="qbtn" onClick={() => remove(item.id)}>−</button>
                    <span className="qnum">{qty}</span>
                    <button className="qbtn" onClick={() => add(item.id)}>+</button>
                  </div>
              }
            </div>
          );
        })}
      </div>
      {count > 0 && (
        <div className="cart-bar">
          <div>
            <div className="cart-count">{count} item{count>1?"s":""}</div>
            <div className="cart-total">Total: ₹{total}</div>
          </div>
          <button className="btn btn-p" onClick={placeOrder} disabled={placing}>
            {placing ? "Placing…" : "Place Order →"}
          </button>
        </div>
      )}
    </div>
  );
}

/* ══════════════════ LAUNDRY ══════════════════ */
function LaundryPage({ go, showToast }) {
  const [tab, setTab]       = useState("new");
  const [type, setType]     = useState("");
  const [qty, setQty]       = useState("");
  const [errors, setErrors] = useState({});
  const [loading, setLoading] = useState(false);
  const [orders, setOrders] = useState(SEED_ORDERS);

  const submit = async () => {
    const e = {};
    if (!type)                         e.type = "Select a cloth type";
    if (!qty||+qty<1||isNaN(+qty))     e.qty  = "Enter valid quantity (≥ 1)";
    setErrors(e);
    if (Object.keys(e).length) return;
    setLoading(true);
    try {
      await fetch("http://localhost:3001/order", {
        method:"POST", headers:{"Content-Type":"application/json"},
        body: JSON.stringify({ clothType:type, quantity:+qty }),
      });
    } catch(_) {}
    const newId = "LND-0" + (44 + orders.length);
    setOrders(prev => [{
      id:newId, clothType:type, quantity:+qty, status:"Processing",
      date: new Date().toLocaleDateString("en-US",{month:"short",day:"numeric"})
    }, ...prev]);
    setType(""); setQty(""); setErrors({});
    setLoading(false); setTab("track");
    showToast("Laundry order " + newId + " placed!");
  };

  return (
    <div className="pg-wrap">
      <PageHeader title="Laundry" icon="👕" back={() => go("services")} />
      <div className="tabs">
        <button className={"tab"+(tab==="new"?" tab-a":"")} onClick={() => setTab("new")}>New Order</button>
        <button className={"tab"+(tab==="track"?" tab-a":"")} onClick={() => setTab("track")}>My Orders ({orders.length})</button>
      </div>

      {tab === "new" && (
        <div className="card">
          <label className="lbl">Select Cloth Type</label>
          <div className="cloth-grid">
            {CLOTH_OPTIONS.map(o => (
              <button key={o.value}
                className={"cloth-btn"+(type===o.value?" cloth-sel":"")}
                onClick={() => { setType(o.value); setErrors(v=>({...v,type:null})); }}>
                <div className="cloth-emoji">{o.emoji}</div>
                <div className="cloth-lbl">{o.label}</div>
              </button>
            ))}
          </div>
          {errors.type && <div className="err-msg">{errors.type}</div>}
          <div className="field" style={{marginTop:"16px"}}>
            <label className="lbl">Quantity</label>
            <input type="number" min="1" placeholder="How many pieces?"
              className={"ctrl"+(errors.qty?" err":"")}
              value={qty} onChange={e => { setQty(e.target.value); setErrors(v=>({...v,qty:null})); }} />
            {errors.qty && <div className="err-msg">{errors.qty}</div>}
          </div>
          <div className="laundry-info">🕐 Pickup within 24hrs · Ready in 48hrs</div>
          <button className="btn btn-p" onClick={submit} disabled={loading}>
            {loading ? <><span className="spin" /> Placing…</> : "Place Laundry Order"}
          </button>
        </div>
      )}

      {tab === "track" && (
        <div className="card">
          <div className="olist">
            {orders.map(o => {
              const s = STATUS_STYLE[o.status] || STATUS_STYLE.Processing;
              return (
                <div className="o-row" key={o.id}>
                  <div className="o-left">
                    <div className="o-ico">{EMOJI_MAP[o.clothType]||"👕"}</div>
                    <div>
                      <div className="o-name">{o.clothType}</div>
                      <div className="o-meta">{typeof o.id==="number"?"LND-0"+o.id:o.id} · {o.date}</div>
                    </div>
                  </div>
                  <div className="o-right">
                    <span className="o-qty">{o.quantity} <small>pcs</small></span>
                    <span className="badge" style={{background:s.bg,color:s.color}}>
                      <span className="bdot" style={{background:s.dot}} />{o.status}
                    </span>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      )}
    </div>
  );
}

/* ══════════════════ SHARED ══════════════════ */
function PageHeader({ title, icon, back }) {
  return (
    <div className="pg-hd">
      <button className="back-btn" onClick={back}>← Back to Services</button>
      <div className="pg-title-row">
        <span className="pg-icon">{icon}</span>
        <h1 className="pg-title">{title}</h1>
      </div>
    </div>
  );
}

/* ══════════════════ CSS ══════════════════ */
const CSS = `
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap');
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Inter',system-ui,sans-serif;background:#f1f5f9;color:#0f172a;min-height:100vh}

.bg-wrap{position:fixed;inset:0;z-index:0}
.bg-img{width:100%;height:100%;object-fit:cover;object-position:center 30%}
.bg-ov{position:absolute;inset:0;background:linear-gradient(to bottom,rgba(255,255,255,0.08) 0%,rgba(255,255,255,0.22) 28%,rgba(241,245,249,0.90) 60%,rgba(241,245,249,0.99) 100%)}

.nav{position:fixed;top:0;left:0;right:0;z-index:100;height:56px;display:flex;align-items:center;justify-content:space-between;padding:0 20px;background:rgba(255,255,255,0.80);backdrop-filter:blur(18px) saturate(1.8);border-bottom:1px solid rgba(15,23,42,0.08)}
.logo{display:flex;align-items:center;gap:9px;background:none;border:none;cursor:pointer;font-size:18px;font-weight:700;color:#0f172a;letter-spacing:-.3px}
.logo-box{width:28px;height:28px;border-radius:7px;background:linear-gradient(135deg,#1d4ed8,#3b82f6);color:#fff;font-size:13px;font-weight:800;display:flex;align-items:center;justify-content:center}
.nav-links{display:flex;gap:2px}
.nb{background:none;border:none;cursor:pointer;font-family:inherit;font-size:13px;font-weight:500;color:#64748b;padding:5px 12px;border-radius:8px;transition:all .13s}
.nb:hover{color:#0f172a;background:rgba(15,23,42,.05)}
.nb-a{color:#1d4ed8 !important;background:rgba(29,78,216,.09) !important;font-weight:600 !important}
.nav-r{display:flex;align-items:center;gap:10px}
.av-sm{width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,#1d4ed8,#60a5fa);color:#fff;font-size:13px;font-weight:700;display:flex;align-items:center;justify-content:center}
.ham{display:none;flex-direction:column;gap:4px;background:none;border:none;cursor:pointer;padding:6px;border-radius:7px}
.ham span{display:block;width:19px;height:1.5px;background:#64748b;border-radius:2px}
.mob-menu{position:fixed;top:56px;left:0;right:0;z-index:99;background:rgba(255,255,255,.97);backdrop-filter:blur(16px);border-bottom:1px solid rgba(15,23,42,.08);padding:8px 14px 14px;display:flex;flex-direction:column;gap:2px}
.mb{background:none;border:none;cursor:pointer;font-family:inherit;font-size:14px;font-weight:500;color:#64748b;padding:9px 14px;border-radius:9px;text-align:left;transition:all .13s}
.mb:hover,.mb-a{color:#1d4ed8;background:rgba(29,78,216,.07);font-weight:600}

.main{position:relative;z-index:1;min-height:100vh;padding:68px 18px 60px}
.main-svc{position:relative;z-index:1;min-height:100vh;padding:56px 18px 60px}
.pg-wrap{max-width:820px;margin:0 auto;padding-top:22px}
.pg-hd{margin-bottom:20px}
.back-btn{background:none;border:none;cursor:pointer;font-family:inherit;font-size:13px;font-weight:600;color:#64748b;padding:4px 0;margin-bottom:10px;display:block;transition:color .13s}
.back-btn:hover{color:#1d4ed8}
.pg-title-row{display:flex;align-items:center;gap:11px}
.pg-icon{font-size:26px}
.pg-title{font-size:clamp(22px,4vw,30px);font-weight:700;color:#0f172a;letter-spacing:-.5px}

.login-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px}
.login-card{background:#fff;border:1px solid #e2e8f0;border-radius:20px;padding:36px;width:100%;max-width:420px;box-shadow:0 4px 24px rgba(15,23,42,.10),0 1px 4px rgba(15,23,42,.06)}
.login-top{display:flex;align-items:center;gap:14px;margin-bottom:24px}
.login-icon-box{width:46px;height:46px;border-radius:12px;flex-shrink:0;background:linear-gradient(135deg,#1d4ed8,#3b82f6);color:#fff;font-size:21px;font-weight:800;display:flex;align-items:center;justify-content:center}
.login-brand{font-size:21px;font-weight:700;color:#0f172a;letter-spacing:-.4px}
.login-sub{font-size:12px;color:#94a3b8;margin-top:2px}
.login-div{height:1px;background:#f1f5f9;margin-bottom:22px}
.login-hint{font-size:11.5px;color:#94a3b8;text-align:center;margin-top:14px;line-height:1.6}
.mt8{margin-top:8px}

.svc-wrap{max-width:900px;margin:0 auto}
.svc-hero{text-align:center;padding:44px 0 32px}
.svc-greet{font-size:14px;font-weight:600;color:#3b82f6;margin-bottom:10px}
.svc-h1{font-size:clamp(28px,5vw,46px);font-weight:700;line-height:1.1;letter-spacing:-1.2px;color:#0f172a;margin-bottom:10px}
.svc-sub{font-size:14px;color:#64748b}
.svc-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:32px}
.svc-card{background:#fff;border:1px solid #e2e8f0;border-radius:16px;padding:22px 16px;cursor:pointer;text-align:center;transition:all .18s;position:relative;box-shadow:0 1px 3px rgba(15,23,42,.05)}
.svc-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(15,23,42,.10);border-color:#bfdbfe}
.svc-dim{opacity:.6;cursor:default}
.svc-dim:hover{transform:none;box-shadow:0 1px 3px rgba(15,23,42,.05);border-color:#e2e8f0}
.svc-emoji{font-size:28px;margin-bottom:10px}
.svc-title{font-size:13px;font-weight:700;color:#0f172a;margin-bottom:4px}
.svc-desc{font-size:11px;color:#94a3b8;line-height:1.5}
.svc-pill{position:absolute;top:10px;right:10px;font-size:9px;font-weight:700;letter-spacing:.4px;text-transform:uppercase;background:#f1f5f9;color:#94a3b8;padding:2px 7px;border-radius:100px}

.stat-row{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:18px}
.stat-card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:14px;text-align:center;box-shadow:0 1px 3px rgba(15,23,42,.05)}
.stat-val{font-size:22px;font-weight:700;letter-spacing:-.5px;margin-bottom:3px}
.stat-lbl{font-size:10.5px;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:#94a3b8}

.tabs{display:flex;gap:4px;margin-bottom:14px;background:rgba(255,255,255,0.65);border:1px solid #e2e8f0;border-radius:11px;padding:4px;width:fit-content;backdrop-filter:blur(8px)}
.tab{background:none;border:none;cursor:pointer;font-family:inherit;font-size:13px;font-weight:600;color:#64748b;padding:6px 15px;border-radius:8px;transition:all .13s}
.tab:hover{color:#0f172a}
.tab-a{background:#fff;color:#1d4ed8;box-shadow:0 1px 4px rgba(15,23,42,.10)}

.card{background:#fff;border:1px solid #e2e8f0;border-radius:16px;padding:20px;margin-bottom:14px;box-shadow:0 1px 4px rgba(15,23,42,.06),0 4px 20px rgba(15,23,42,.04)}

.field{margin-bottom:13px}
.lbl{display:block;font-size:10.5px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:#94a3b8;margin-bottom:6px}
.ctrl{width:100%;background:#f8fafc;border:1.5px solid #e2e8f0;border-radius:10px;color:#0f172a;font-family:inherit;font-size:14px;padding:10px 12px;outline:none;transition:border-color .13s;-webkit-appearance:none}
.ctrl:hover{border-color:#cbd5e1}
.ctrl:focus{border-color:#3b82f6;background:#fff;box-shadow:0 0 0 3px rgba(59,130,246,.10)}
.ctrl.err{border-color:#ef4444;box-shadow:0 0 0 3px rgba(239,68,68,.08)}
.ctrl::placeholder{color:#c4c9d4}
.ctrl option{background:#fff;color:#0f172a}
.ta{resize:vertical;min-height:88px;line-height:1.6}
.err-msg{font-size:11.5px;color:#ef4444;margin-top:5px;font-weight:500}

.btn{display:inline-flex;align-items:center;justify-content:center;gap:7px;font-family:inherit;font-size:13.5px;font-weight:600;border-radius:10px;cursor:pointer;padding:10px 20px;transition:all .15s;white-space:nowrap;border:none}
.btn:disabled{opacity:.45;cursor:not-allowed;transform:none !important}
.btn-p{background:linear-gradient(135deg,#1d4ed8,#3b82f6);color:#fff;box-shadow:0 2px 10px rgba(59,130,246,.30)}
.btn-p:not(:disabled):hover{transform:translateY(-1px);box-shadow:0 4px 18px rgba(59,130,246,.42)}
.full{width:100%}
.spin{display:inline-block;width:13px;height:13px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .65s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}

.tbl{width:100%;border-collapse:collapse;font-size:13.5px}
.tbl th{text-align:left;font-size:10px;font-weight:700;letter-spacing:.7px;text-transform:uppercase;color:#94a3b8;padding:7px 10px 10px;border-bottom:1.5px solid #f1f5f9}
.tbl td{padding:10px 10px;border-bottom:1px solid #f8fafc;color:#334155}
.tbl tr:last-child td{border-bottom:none}
.tbl tr:hover td{background:#f8fafc}
.tc{text-align:center}
.mono{font-family:'JetBrains Mono',monospace;font-size:12px;color:#64748b}

.att-list{display:flex;flex-direction:column;gap:13px}
.att-row{display:flex;align-items:center;justify-content:space-between;gap:16px}
.att-name{font-size:13.5px;font-weight:600;color:#0f172a}
.att-code{font-size:11px;color:#94a3b8;font-family:monospace}
.att-bar-wrap{display:flex;align-items:center;gap:10px;flex:1;max-width:260px}
.att-bar{flex:1;height:7px;background:#f1f5f9;border-radius:100px;overflow:hidden}
.att-fill{height:100%;border-radius:100px;transition:width .4s}
.att-pct{font-size:12px;font-weight:700;min-width:36px;text-align:right}
.att-note{margin-top:16px;font-size:12px;color:#92400e;background:#fff7ed;border:1px solid #fed7aa;border-radius:9px;padding:10px 13px}

.tt-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:8px}
.tt-col{display:flex;flex-direction:column;gap:6px}
.tt-day{font-size:10.5px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:#1d4ed8;background:#eff6ff;border-radius:7px;padding:6px;text-align:center}
.tt-slot{font-size:11px;font-weight:500;color:#334155;background:#f8fafc;border:1px solid #f1f5f9;border-radius:7px;padding:7px 6px;text-align:center;line-height:1.4}

.c-row{display:flex;align-items:flex-start;justify-content:space-between;padding:13px 0;border-bottom:1px solid #f8fafc;gap:12px}
.c-row:last-child{border-bottom:none}
.c-id{font-size:10.5px;font-family:monospace;color:#94a3b8;margin-bottom:2px}
.c-title{font-size:13.5px;font-weight:600;color:#0f172a;margin-bottom:2px}
.c-cat{font-size:11.5px;color:#94a3b8}

.food-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:14px}
.food-card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:18px;text-align:center;box-shadow:0 1px 3px rgba(15,23,42,.05)}
.food-emoji{font-size:28px;margin-bottom:8px}
.food-name{font-size:13px;font-weight:600;color:#0f172a;margin-bottom:4px}
.food-price{font-size:13px;font-weight:700;color:#1d4ed8;margin-bottom:12px}
.btn-add{background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe;font-size:12px;font-weight:600;padding:6px 14px;border-radius:8px;cursor:pointer;font-family:inherit;transition:all .13s}
.btn-add:hover{background:#dbeafe}
.qty-ctrl{display:flex;align-items:center;justify-content:center;gap:10px}
.qbtn{width:28px;height:28px;border-radius:7px;background:#eff6ff;color:#1d4ed8;font-size:16px;border:1px solid #bfdbfe;cursor:pointer;font-weight:700;display:flex;align-items:center;justify-content:center;transition:all .13s}
.qbtn:hover{background:#dbeafe}
.qnum{font-size:15px;font-weight:700;color:#0f172a;min-width:18px;text-align:center}
.cart-bar{position:sticky;bottom:16px;background:#fff;border:1px solid #bfdbfe;border-radius:15px;padding:13px 18px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 8px 24px rgba(29,78,216,.14)}
.cart-count{font-size:11.5px;font-weight:600;color:#64748b}
.cart-total{font-size:16px;font-weight:700;color:#0f172a}

.cloth-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:4px}
.cloth-btn{background:#f8fafc;border:1.5px solid #e2e8f0;border-radius:12px;padding:14px 8px;cursor:pointer;text-align:center;transition:all .14s}
.cloth-btn:hover{border-color:#93c5fd;background:#eff6ff}
.cloth-sel{border-color:#3b82f6 !important;background:#eff6ff !important;box-shadow:0 0 0 3px rgba(59,130,246,.12)}
.cloth-emoji{font-size:22px;margin-bottom:5px}
.cloth-lbl{font-size:11px;font-weight:600;color:#334155}
.laundry-info{font-size:12px;color:#64748b;background:#f8fafc;border:1px solid #e2e8f0;border-radius:9px;padding:10px 13px;margin-bottom:13px;display:flex;align-items:center;gap:7px}

.olist{display:flex;flex-direction:column;gap:6px}
.o-row{display:flex;align-items:center;justify-content:space-between;padding:11px 13px;border-radius:11px;background:#f8fafc;border:1px solid #f1f5f9;transition:background .13s}
.o-row:hover{background:#f1f5f9}
.o-left{display:flex;align-items:center;gap:11px}
.o-ico{width:36px;height:36px;border-radius:9px;background:#eff6ff;border:1px solid #bfdbfe;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.o-name{font-size:13.5px;font-weight:600;color:#0f172a;text-transform:capitalize}
.o-meta{font-size:11px;color:#94a3b8;margin-top:1px;font-family:monospace}
.o-right{display:flex;align-items:center;gap:10px}
.o-qty{font-size:14px;font-weight:700;color:#1d4ed8}
.o-qty small{font-size:10px;color:#94a3b8;font-weight:500}

.badge{display:inline-flex;align-items:center;gap:5px;flex-shrink:0;font-size:10.5px;font-weight:700;padding:3px 9px;border-radius:100px}
.bdot{width:5px;height:5px;border-radius:50%;flex-shrink:0}

.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:200;background:#fff;border:1px solid #bbf7d0;border-radius:12px;padding:11px 20px;display:flex;align-items:center;gap:9px;box-shadow:0 8px 28px rgba(15,23,42,.14);font-size:13px;font-weight:600;white-space:nowrap;animation:slideUp .35s cubic-bezier(.34,1.56,.64,1)}
@keyframes slideUp{from{transform:translateX(-50%) translateY(60px);opacity:0}to{transform:translateX(-50%) translateY(0);opacity:1}}
.toast-success{color:#166534}
.toast-success .toast-ic{background:#dcfce7;color:#16a34a;width:19px;height:19px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px}

@media(max-width:700px){
  .svc-grid{grid-template-columns:repeat(2,1fr)}
  .stat-row{grid-template-columns:repeat(2,1fr)}
  .tt-grid{grid-template-columns:repeat(3,1fr)}
  .food-grid{grid-template-columns:repeat(2,1fr)}
  .cloth-grid{grid-template-columns:repeat(3,1fr)}
  .nav-links{display:none}
  .ham{display:flex !important}
  .att-row{flex-direction:column;align-items:flex-start;gap:8px}
  .att-bar-wrap{width:100%;max-width:none}
  .o-right{flex-direction:column;align-items:flex-end;gap:4px}
}
`;
